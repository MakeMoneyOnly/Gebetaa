{
    "name": "gebeta-menu",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "build:analyze": "ANALYZE=true next build",
        "start": "next start",
        "cap:sync:android": "cap sync android",
        "cap:open:android": "cap open android",
        "supabase:cli": "cross-env DOCKER_CONFIG=.docker supabase",
        "lint": "eslint",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "test:e2e": "playwright test",
        "test:ci": "pnpm lint && pnpm type-check && pnpm test:coverage && pnpm exec playwright test --project=chromium",
        "type-check": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "tokens:build": "style-dictionary build",
        "prepare": "husky",
        "codegen": "graphql-codegen --config codegen.yml",
        "security:precommit": "node scripts/security/precommit-security.mjs",
        "bundle:analyze": "next experimental-analyze",
        "security:audit": "pnpm audit --audit-level=high",
        "security:audit:fix": "pnpm audit --fix",
        "security:outdated": "pnpm outdated",
        "security:deprecated": "node scripts/security/check-deprecated.mjs",
        "security:overrides:check": "node scripts/security/check-unused-overrides.mjs",
        "deps:update": "pnpm update --interactive --latest",
        "deps:clean": "pnpm store prune"
    },
    "dependencies": {
        "@apollo/server": "^5.5.0",
        "@apollo/subgraph": "^2.9.0",
        "@as-integrations/next": "^4.1.0",
