{
    "ci": {
        "collect": {
            "startServerCommand": "npm run start",
            "startServerReadyPattern": "ready on|Ready in",
            "startServerReadyTimeout": 30000,
            "url": ["http://localhost:3000"],
            "numberOfRuns": 1
        },
        "assert": {
            "preset": "lighthouse:no-pwa",
            "assertions": {
                "categories:performance": [
                    "warn",
                    {
                        "minScore": 0.5
                    }
                ],
                "categories:accessibility": [
                    "warn",
                    {
                        "minScore": 0.7
                    }
                ],
                "categories:best-practices": [
                    "warn",
                    {
                        "minScore": 0.7
                    }
                ],
                "categories:seo": [
                    "warn",
                    {
                        "minScore": 0.7
                    }
                ],
                "first-contentful-paint": "off",
                "largest-contentful-paint": "off",
                "cumulative-layout-shift": "off",
                "total-blocking-time": "off",
                "speed-index": "off",
                "interactive": "off",
                "max-potential-fid": "off",
                "uses-responsive-images": "warn",
                "offscreen-images": "off",
                "unminified-css": "warn",
                "unminified-javascript": "warn",
                "unused-css-rules": "off",
                "unused-javascript": "off",
                "modern-image-formats": "off",
                "uses-optimized-images": "off",
                "uses-text-compression": "off",
                "uses-rel-preconnect": "off",
                "font-display": "off",
                "duplicated-javascript": "off",
                "legacy-javascript": "off",
                "meta-description": "off",
                "document-title": "off",
                "html-has-lang": "off",
                "link-text": "off",
                "crawlable-anchors": "off",
                "is-crawlable": "off",
                "robots-txt": "off",
                "http-status-code": "off",
                "errors-in-console": "off",
                "image-alt": "off",
                "color-contrast": "off",
                "tap-targets": "off",
                "font-size": "off",
                "link-name": "off",
                "bf-cache": "off",
                "redirects": "off",
                "viewport": "off",
                "structured-data": "off",
                "canonical": "off",
                "hreflang": "off",
                "plugins": "off",
                "is-on-https": "off",
                "service-worker": "off",
                "maskable-icon": "off",
                "render-blocking-resources": "off",
                "dom-size": "off",
                "bootup-time": "off",
                "mainthread-work-breakdown": "off",
                "server-response-time": "off",
                "third-party-summary": "off",
                "third-party-facades": "off",
                "unsized-images": "off",
                "preload-lcp-image": "off",
                "uses-long-cache-ttl": "off",
                "total-byte-weight": "off",
                "no-document-write": "off",
                "geolocation-on-start": "off",
                "notification-on-start": "off",
                "no-vulnerable-libraries": "off",
                "csp-xss": "off",
                "paste-preventing-inputs": "off",
                "image-aspect-ratio": "off",
                "image-size-responsive": "off",
                "deprecations": "off",
                "inspector-issues": "off",
                "charset": "off",
                "valid-source-maps": "off",
                "js-libraries": "off",
                "duplicated-javascript": "off",
                "prioritize-lcp-image": "off",
                "non-composited-animations": "off",
                "largest-contentful-paint-element": "off",
                "layout-shift-elements": "off",
                "long-tasks": "off",
                "uses-passive-event-listeners": "off",
                "label": "off",
                "button-name": "off",
                "aria-allowed-attr": "off",
                "aria-hidden-body": "off",
                "aria-valid-attr-value": "off",
                "aria-valid-attr": "off",
                "heading-order": "off",
                "tabindex": "off",
                "list": "off",
                "listitem": "off",
                "definition-list": "off",
                "dlitem": "off",
                "bypass": "off",
                "frame-title": "off",
                "input-image-alt": "off",
                "td-headers-attr": "off",
                "th-has-data-cells": "off",
                "valid-lang": "off",
                "accesskeys": "off",
                "html-xml-lang-mismatch": "off",
                "duplicate-id-aria": "off",
                "duplicate-id-active": "off",
                "aria-required-attr": "off",
                "aria-required-children": "off",
                "aria-required-parent": "off",
                "aria-roles": "off",
                "aria-toggle-field-name": "off",
                "aria-input-field-name": "off",
                "form-field-multiple-labels": "off",
                "aria-meter-name": "off",
                "aria-progressbar-name": "off",
                "aria-treeitem-name": "off",
                "meta-refresh": "off",
                "meta-viewport": "off",
                "object-alt": "off",
                "select-name": "off",
                "skip-link": "off",
                "video-caption": "off",
                "video-description": "off"
            }
        },
        "upload": {
            "target": "temporary-public-storage"
        }
    }
}
