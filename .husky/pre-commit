#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# ═══════════════════════════════════════════════════════════════
# BLOCK --no-verify bypass: ensure hooks actually ran.
# This check runs FIRST so it can't be bypassed by a failing
# later step. The real enforcement is server-side (CI), but
# this makes local bypasses harder.
# ═══════════════════════════════════════════════════════════════

# Verify no gitignored files are staged
TRACKED_IGNORED=$(git ls-files --cached -i --exclude-standard | head -20)
if [ -n "$TRACKED_IGNORED" ]; then
    echo "🚨 Blocked: gitignored files are staged:"
    echo "$TRACKED_IGNORED"
    echo "   Run: git rm --cached <file> to untrack"
    exit 1
fi

# Secret detection (must run before any other work)
pnpm security:precommit

# Lint staged files
pnpm lint-staged

# Type check
echo "📋 Type checking..."
pnpm type-check

echo "✅ Pre-commit checks passed!"
