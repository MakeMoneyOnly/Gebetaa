# ═══════════════════════════════════════════════════════════════════════════════
# lole RESTAURANT OS - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# COMPLETE list of ALL environment variables needed across the platform.
# Copy this file to .env.local and fill in your values.
#
# Legend:
#   [REQUIRED]  - Must be set for the application to work
#   [OPTIONAL]  - Enhances functionality but not required
#   [SECRET]    - Never expose to client-side (server-only)
#   [PUBLIC]    - Safe to expose to client-side (NEXT_PUBLIC_ prefix)
#   [SPRINT]    - Required for specific implementation sprint
#   [CI]        - Only needed in CI/CD pipelines (GitHub Secrets)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# CORE APPLICATION
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED][PUBLIC] Application URL (used for generating links, webhooks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL][PUBLIC] Base URL (alternative to APP_URL, used in payment mock flows)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# [OPTIONAL][PUBLIC] Site URL (for SEO, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# [OPTIONAL][PUBLIC] Application name (defaults to "lole")
NEXT_PUBLIC_APP_NAME=lole

# [OPTIONAL][PUBLIC] Version for health checks and monitoring
NEXT_PUBLIC_VERSION=0.1.0

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE - PRIMARY DATABASE & AUTH
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED][PUBLIC] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED][PUBLIC] Modern publishable key (format: sb_publishable_...)
# Used for client-side authentication
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# [REQUIRED][SECRET] Service role key - NEVER expose to client!
# Used for server-side admin operations
SUPABASE_SECRET_KEY=your_service_role_key_here

# [OPTIONAL][PUBLIC] Legacy anon key (still used by some API routes and audit module)
# Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# [OPTIONAL][SECRET] Alternative service role key name (fallback used by integration tests)
# Set to same value as SUPABASE_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# [OPTIONAL][SECRET] App-safe database connection string (Supavisor / pooler only)
# Default lane for app/runtime SQL traffic. Must be safe for serverless.
# Format: postgresql://postgres:[PASSWORD]@pooler.[PROJECT-REF].supabase.co:6543/postgres
DATABASE_URL=postgresql://postgres:password@pooler.your-project.supabase.co:6543/postgres

# [OPTIONAL][SECRET] Infra-only direct Postgres URL
# Reserved for PowerSync replication, migrations, CI psql, and admin scripts.
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# [OPTIONAL][SECRET] Alias for the direct database URL (used by CI/CD and scripts)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# [OPTIONAL][SECRET] Database password (used by connection-pooling.ts for dynamic URL construction)
SUPABASE_DB_PASSWORD=your_db_password

# [OPTIONAL][SECRET] Supabase access token for CLI/CI operations
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# [OPTIONAL] Supabase project reference (used by migration drift check CI)
SUPABASE_PROJECT_REF=your_project_ref

# [OPTIONAL] Supabase region for pooler host construction (default: eu-central-1)
SUPABASE_REGION=eu-central-1

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE - CONNECTION POOLING (SUPAVISOR)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Connection pool mode: 'transaction' (default) or 'session'
SUPABASE_POOL_MODE=transaction

# [OPTIONAL] Pool size: number of connections per pooler instance (default: 10)
SUPABASE_POOL_SIZE=10

# [OPTIONAL] Maximum number of clients in the pool (default: 20)
SUPABASE_POOL_MAX_CLIENTS=20

# [OPTIONAL] Connection timeout in seconds (default: 30)
SUPABASE_POOL_CONNECTION_TIMEOUT=30

# [OPTIONAL] Idle timeout in seconds (default: 1800 = 30 minutes)
SUPABASE_POOL_IDLE_TIMEOUT=1800

# [OPTIONAL][SECRET] Database connection string for Supavisor pooler
# Format: postgresql://postgres:[PASSWORD]@pooler.[PROJECT-REF].supabase.co:6543/postgres
SUPABASE_POOLER_URL=postgresql://postgres:password@pooler.your-project.supabase.co:6543/postgres

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED][SECRET] JWT secret for token signing (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# [REQUIRED][SECRET] HMAC secret for QR code signing (min 32 characters)
# Used for guest menu session URLs
HMAC_SECRET=your-super-secret-hmac-key-at-least-32-chars

# [REQUIRED][SECRET] QR HMAC secret for guest session URLs (min 32 characters)
QR_HMAC_SECRET=your-super-secret-qr-hmac-key-at-least-32-chars

# [OPTIONAL][SECRET] Device token signature secret (falls back to AUTH_SECRET or HMAC_SECRET)
DEVICE_TOKEN_SIGNATURE_SECRET=your_device_token_signing_secret

# [OPTIONAL][SECRET] Auth secret (fallback for device token signing)
AUTH_SECRET=your_auth_secret

# [OPTIONAL][SECRET] Comma-separated list of additional allowed hosts (host-validation.ts)
ALLOWED_HOSTS=

# [OPTIONAL][SECRET] Comma-separated list of additional allowed origins (CSRF protection)
ALLOWED_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENTS - CHAPA (Ethiopian Payment Gateway)
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED][SECRET] Chapa secret key for payment API
# Get from: https://chapa.co/dashboard
CHAPA_SECRET_KEY=your_chapa_secret_key

# [OPTIONAL] Chapa public key for client-side payment initialization
CHAPA_PUBLIC_KEY=your_chapa_public_key

# [OPTIONAL][SECRET] Chapa API URL override (default: https://api.chapa.co/v1)
CHAPA_API_URL=https://api.chapa.co/v1

# [OPTIONAL][SECRET] Chapa webhook secret for production signature verification
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret

# [OPTIONAL][SECRET] Chapa webhook test secret for sandbox/test signature verification
CHAPA_WEBHOOK_TEST_SECRET=your_chapa_webhook_test_secret

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENTS - TELEBIRR (Telebirr Mobile Money)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Telebirr App ID
# Get from: Telebirr merchant portal
TELEBIRR_APP_ID=your_telebirr_app_id

# [OPTIONAL][SECRET] Telebirr App Key
TELEBIRR_APP_KEY=your_telebirr_app_key

# ═══════════════════════════════════════════════════════════════════════════════
# ADDITIONAL PAYMENT PROVIDERS [PHASE 2]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] CBE Birr merchant ID
CBE_BIRR_MERCHANT_ID=your_merchant_id

# [OPTIONAL][SECRET] CBE Birr API key
CBE_BIRR_API_KEY=your_cbe_birr_api_key

# [OPTIONAL] Amole (Dashen Bank) merchant ID
AMOLE_MERCHANT_ID=your_amole_merchant_id

# [OPTIONAL][SECRET] Amole API key
AMOLE_API_KEY=your_amole_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# UPSTASH - REDIS CACHE & EVENT BUS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Upstash Redis REST URL
# Used for: menu caching, session storage, rate limiting, event bus (Redis Streams)
# Get from: https://upstash.com/console
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# [OPTIONAL][SECRET] Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# [OPTIONAL][SECRET] Legacy Redis URL (alternative to Upstash REST API, for ioredis)
REDIS_URL=redis://default:password@redis-host:6379

# ═══════════════════════════════════════════════════════════════════════════════
# UPSTASH QSTASH - JOB QUEUE [SPRINT 1.4]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] QStash token for background job processing
# Used for: payment retries, ERCA submissions, EOD reports, loyalty awards
# Get from: https://upstash.com/console/qstash
QSTASH_TOKEN=your_qstash_token

# [OPTIONAL][SECRET] Current signing key for QStash webhook verification
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key

# [OPTIONAL][SECRET] Next signing key for QStash webhook verification
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# ═══════════════════════════════════════════════════════════════════════════════
# POWERSYNC - OFFLINE-FIRST SYNC [SPRINT 4]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][PUBLIC] PowerSync instance URL/endpoint
# Used for: offline-first POS/KDS sync with CRDT conflict resolution
# Get from: https://console.powersync.com/
NEXT_PUBLIC_POWERSYNC_ENDPOINT=https://your-instance.powersync.co

# [OPTIONAL][PUBLIC] Development token for local PowerSync bring-up only
# Remove in production after PowerSync is configured to trust Supabase JWTs.
NEXT_PUBLIC_POWERSYNC_DEV_TOKEN=your_powersync_dev_token

# [OPTIONAL][SECRET] Direct Postgres URL for PowerSync replication connector
# This must use direct Postgres, never the pooler.
POWERSYNC_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ═══════════════════════════════════════════════════════════════════════════════
# APOLLO GRAPHQL - API FEDERATION [SPRINT 6]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Apollo Studio graph ID for schema management
# Get from: https://studio.apollographql.com/
APOLLO_GRAPH_ID=your_graph_id

# [OPTIONAL][SECRET] Apollo Studio API key
APOLLO_KEY=your_apollo_key

# [OPTIONAL][SECRET] Apollo router supergraph schema path
APOLLO_ROUTER_SUPERGRAPH_PATH=./supergraph.graphql

# [OPTIONAL] Enable GraphQL introspection in Apollo Router (disabled by default for security)
APOLLO_ROUTER_INTROSPECTION=false

# [OPTIONAL] Enable GraphQL introspection (alternative flag used by graphql/config.ts)
GRAPHQL_ENABLE_INTROSPECTION=false

# ═══════════════════════════════════════════════════════════════════════════════
# SENTRY - ERROR MONITORING [SPRINT 1.6]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][PUBLIC] Sentry DSN for client-side error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# [OPTIONAL][SECRET] Sentry auth token for server-side operations and sourcemaps
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# [OPTIONAL] Sentry organization slug
SENTRY_ORG=your_sentry_org

# [OPTIONAL] Sentry project slug
SENTRY_PROJECT=your_sentry_project

# ═══════════════════════════════════════════════════════════════════════════════
# RESEND - TRANSACTIONAL EMAIL
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED][SECRET] Resend API key for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# [OPTIONAL] From email address for outgoing emails (default: onboarding@resend.dev)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ═══════════════════════════════════════════════════════════════════════════════
# TELEGRAM - ALERTING [SPRINT 7.6]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Telegram bot token for sending alerts
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# [OPTIONAL] Telegram chat ID for receiving alerts
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_ALERT_CHAT_ID=your_telegram_chat_id

# [OPTIONAL] Telegram chat ID for EOD reports (can be same as ALERT_CHAT_ID)
TELEGRAM_EOD_CHAT_ID=your_telegram_chat_id

# ═══════════════════════════════════════════════════════════════════════════════
# AFRICA'S TALKING - SMS NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] SMS provider: 'africas_talking' or 'log' (default: 'log')
SMS_PROVIDER=log

# [OPTIONAL][SECRET] Africa's Talking API key
# Get from: https://account.africastalking.com/
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key

# [OPTIONAL] Africa's Talking username
AFRICAS_TALKING_USERNAME=your_username

# [OPTIONAL] Sender ID (alphanumeric, max 11 chars) for SMS
AFRICAS_TALKING_SENDER_ID=lole

# ═══════════════════════════════════════════════════════════════════════════════
# PUSH NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Push notification provider: 'firebase', 'vapid', or 'log' (default: 'log')
PUSH_PROVIDER=log

# --- Firebase Cloud Messaging (FCM) ---

# [OPTIONAL][SECRET] Firebase project ID for FCM push notifications
FIREBASE_PROJECT_ID=your_firebase_project_id

# [OPTIONAL][SECRET] Firebase client email for service account
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# [OPTIONAL][SECRET] Firebase private key for service account (include \n as literal)
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# --- Web Push (VAPID) ---

# [OPTIONAL][PUBLIC] VAPID public key for web push notifications
VAPID_PUBLIC_KEY=your_vapid_public_key

# [OPTIONAL][SECRET] VAPID private key for web push notifications
VAPID_PRIVATE_KEY=your_vapid_private_key

# [OPTIONAL] VAPID subject (mailto: or https:// URL)
VAPID_SUBJECT=mailto:dev@lole.app

# ═══════════════════════════════════════════════════════════════════════════════
# ERCA - ETHIOPIAN REVENUE COMPLIANCE [SPRINT 8]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] ERCA e-Invoice API URL (production or sandbox)
ERCA_API_URL=https://erca.gov.et/api/invoices

# [OPTIONAL][SECRET] ERCA API endpoint (used by jobs/erca/submit route)
ERCA_API_ENDPOINT=https://erca.gov.et/api/invoices

# [OPTIONAL][SECRET] ERCA API key for e-invoicing
ERCA_API_KEY=your_erca_api_key

# [OPTIONAL][SECRET] ERCA certificate path for e-invoice signing
ERCA_CERTIFICATE_PATH=/path/to/erca-cert.pem

# [OPTIONAL] ERCA sandbox mode: 'true' to use test environment
ERCA_SANDBOX_MODE=true

# ═══════════════════════════════════════════════════════════════════════════════
# MoR FISCAL - MINISTRY OF REVENUE FISCAL REPORTING
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] MoR Fiscal API URL for fiscal receipt reporting
MOR_FISCAL_API_URL=https://api.mor.gov.et/fiscal

# [OPTIONAL][SECRET] MoR Fiscal API key
MOR_FISCAL_API_KEY=your_mor_fiscal_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUDFLARE - CDN, WAF & STORAGE [SPRINT 7]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Cloudflare account ID
# Get from: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# [OPTIONAL][SECRET] Cloudflare API token (for Workers, R2, DNS management)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# [OPTIONAL][SECRET] Cloudflare R2 access key ID (S3-compatible storage)
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key

# [OPTIONAL][SECRET] Cloudflare R2 secret access key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key

# [OPTIONAL] Cloudflare R2 bucket name for receipts, menu images, exports
CLOUDFLARE_R2_BUCKET_NAME=lole-storage

# [OPTIONAL] Cloudflare R2 public URL
CLOUDFLARE_R2_PUBLIC_URL=https://storage.lole.app

# ═══════════════════════════════════════════════════════════════════════════════
# DELIVERY CHANNEL INTEGRATIONS [PHASE 2]
# ═══════════════════════════════════════════════════════════════════════════════

# --- BEU (delivery partner) ---

# [OPTIONAL][SECRET] BEU API key
BEU_API_KEY=your_beu_api_key

# [OPTIONAL][SECRET] BEU API secret
BEU_API_SECRET=your_beu_api_secret

# [OPTIONAL] BEU API base URL
BEU_API_BASE_URL=https://api.beu.et

# [OPTIONAL] BEU order acknowledgment URL
BEU_ACK_URL=https://api.beu.et/orders/ack

# --- Zmall ---

# [OPTIONAL][SECRET] Zmall API key
ZMALL_API_KEY=your_zmall_api_key

# [OPTIONAL][SECRET] Zmall API secret
ZMALL_API_SECRET=your_zmall_api_secret

# [OPTIONAL] Zmall API base URL
ZMALL_API_BASE_URL=https://api.zmall.et

# [OPTIONAL] Zmall order acknowledgment URL
ZMALL_ACK_URL=https://api.zmall.et/orders/acknowledge

# --- Deliver Addis ---

# [OPTIONAL][SECRET] Deliver Addis API key
DELIVER_ADDIS_API_KEY=your_deliver_addis_api_key

# [OPTIONAL][SECRET] Deliver Addis API secret
DELIVER_ADDIS_API_SECRET=your_deliver_addis_api_secret

# [OPTIONAL] Deliver Addis API base URL
DELIVER_ADDIS_API_BASE_URL=https://api.deliveraddis.com

# [OPTIONAL] Deliver Addis order acknowledgment URL
DELIVER_ADDIS_ACK_URL=https://api.deliveraddis.com/orders/accept

# [OPTIONAL][SECRET] Deliver Addis fleet API key
DELIVER_ADDIS_FLEET_KEY=your_deliver_addis_fleet_key

# [OPTIONAL] Deliver Addis fleet URL
DELIVER_ADDIS_FLEET_URL=https://fleet.deliveraddis.com

# --- Esoora ---

# [OPTIONAL][SECRET] Esoora API key
ESOORA_API_KEY=your_esoora_api_key

# [OPTIONAL][SECRET] Esoora API secret
ESOORA_API_SECRET=your_esoora_api_secret

# [OPTIONAL] Esoora API base URL
ESOORA_API_BASE_URL=https://api.esoora.et

# [OPTIONAL] Esoora order acknowledgment URL
ESOORA_ACK_URL=https://api.esoora.et/orders/ack

# --- Fidel Delivery ---

# [OPTIONAL][SECRET] Fidel delivery API key
FIDEL_API_KEY=your_fidel_api_key

# [OPTIONAL] Fidel delivery API URL
FIDEL_API_URL=https://api.fideldelivery.com

# --- Delivery Webhook Security ---

# [OPTIONAL][SECRET] Delivery aggregator webhook secret for HMAC verification
DELIVERY_WEBHOOK_SECRET=your_delivery_webhook_secret

# ═══════════════════════════════════════════════════════════════════════════════
# ESPER - DEVICE MANAGEMENT (MDM)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Esper API key for device management
ESPER_API_KEY=your_esper_api_key

# [OPTIONAL] Esper API base URL
ESPER_API_BASE_URL=https://your-tenant.esper.cloud/api

# [OPTIONAL] Esper tenant name
ESPER_TENANT_NAME=your_tenant_name

# [OPTIONAL] Esper enterprise ID
ESPER_ENTERPRISE_ID=your_enterprise_id

# [OPTIONAL] Esper app package name for device provisioning
ESPER_APP_PACKAGE_NAME=com.lole.device

# ═══════════════════════════════════════════════════════════════════════════════
# CAPACITOR - NATIVE DEVICE SHELL
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Capacitor app ID (alternative to hardcoded default)
CAPACITOR_APP_ID=com.lole.device

# [OPTIONAL] Capacitor server URL for live reload during development
CAPACITOR_SERVER_URL=http://localhost:3000

# [OPTIONAL][PUBLIC] Capacitor server URL (public variant)
NEXT_PUBLIC_CAPACITOR_SERVER_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# VERCEL - DEPLOYMENT PLATFORM
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Vercel token for CLI/CI deployments
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token

# [OPTIONAL] Vercel organization ID
VERCEL_ORG_ID=your_org_id

# [OPTIONAL] Vercel project ID
VERCEL_PROJECT_ID=your_project_id

# [OPTIONAL][PUBLIC] Vercel environment indicator (auto-set by Vercel)
NEXT_PUBLIC_VERCEL_ENV=

# [OPTIONAL][PUBLIC] Vercel deployment URL (auto-set by Vercel)
NEXT_PUBLIC_VERCEL_URL=

# [OPTIONAL][PUBLIC] Vercel production project URL (auto-set by Vercel)
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# RAILWAY - APOLLO ROUTER HOSTING [SPRINT 6.8]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Railway token for Apollo Router deployment
# Get from: https://railway.app/account/tokens
RAILWAY_TOKEN=your_railway_token

# [OPTIONAL] Railway service name for Apollo Router
RAILWAY_SERVICE_NAME=apollo-router

# ═══════════════════════════════════════════════════════════════════════════════
# MANAGER APP - EXPO/REACT NATIVE [SPRINT 9]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Expo application ID for manager app
EXPO_APP_ID=your_expo_app_id

# [OPTIONAL][SECRET] Expo access token for EAS Build
EXPO_TOKEN=your_expo_token

# ═══════════════════════════════════════════════════════════════════════════════
# KDS PRINTER WEBHOOK
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Secret for KDS printer webhook authentication (min 16 chars)
KDS_PRINTER_WEBHOOK_SECRET=your_printer_webhook_secret

# ═══════════════════════════════════════════════════════════════════════════════
# WEBHOOK SECRETS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Guest order status webhook secret for signature verification
GUEST_ORDER_STATUS_WEBHOOK_SECRET=your_guest_order_status_webhook_secret

# ═══════════════════════════════════════════════════════════════════════════════
# METRICS & MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] API key for /api/metrics endpoint
METRICS_API_KEY=your_metrics_api_key

# [OPTIONAL][PUBLIC] Analytics endpoint URL for performance monitoring
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# ═══════════════════════════════════════════════════════════════════════════════
# ANALYTICS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][PUBLIC] Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# [OPTIONAL] Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# HEALTH CHECK & OPERATIONS SECRETS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Health check endpoint secret (for production auth on /api/health)
HEALTH_CHECK_SECRET=your_health_check_secret

# [OPTIONAL][SECRET] Test alerts endpoint secret (for /api/test-alerts auth)
TEST_ALERTS_SECRET=your_test_alerts_secret

# [OPTIONAL][SECRET] Cron job authentication secret (for scheduled job routes)
CRON_SECRET=your_cron_secret

# ═══════════════════════════════════════════════════════════════════════════════
# N8N - WORKFLOW AUTOMATION
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][PUBLIC] n8n webhook URL for restaurant order workflows
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/restaurant-order

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Enable offline mode support
ENABLE_OFFLINE_MODE=true

# [OPTIONAL] Enable AR menu feature
ENABLE_AR_MENU=false

# [OPTIONAL] Enable analytics features
ENABLE_ANALYTICS=true

# [OPTIONAL] Enable rate limiting
RATE_LIMIT_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# RATE LIMITING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Rate limit: max requests per window (production default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# [OPTIONAL] Rate limit: window size in seconds (default: 60)
RATE_LIMIT_WINDOW_SECONDS=60

# [OPTIONAL] Rate limit: max auth requests per window (production default: 10)
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ═══════════════════════════════════════════════════════════════════════════════
# PILOT ROLLOUT FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Enable P0 pilot rollout
ENABLE_P0_PILOT_ROLLOUT=false

# [OPTIONAL] Enable P1 pilot rollout
ENABLE_P1_PILOT_ROLLOUT=false

# [OPTIONAL] Enable P2 pilot rollout
ENABLE_P2_PILOT_ROLLOUT=false

# [OPTIONAL] Comma-separated list of pilot restaurant IDs
PILOT_RESTAURANT_IDS=

# [OPTIONAL] Block mutations for pilot restaurants (read-only mode)
PILOT_BLOCK_MUTATIONS=false

# ═══════════════════════════════════════════════════════════════════════════════
# SESSION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Session timeout in minutes (default: 30, range: 5-480)
SESSION_TIMEOUT_MINUTES=30

# [OPTIONAL] Session max lifetime in hours (default: 8, range: 1-24)
SESSION_MAX_LIFETIME_HOURS=8

# ═══════════════════════════════════════════════════════════════════════════════
# E2E TESTING - DEVELOPMENT ONLY
# ═══════════════════════════════════════════════════════════════════════════════
# These variables enable E2E test authentication bypass in non-production environments.
# NEVER enable these in production!

# [OPTIONAL] Enable E2E test mode (only works in non-production)
E2E_TEST_MODE=false

# [OPTIONAL][SECRET] Secret value required for E2E auth bypass
E2E_BYPASS_SECRET=your_e2e_bypass_secret_here

# [OPTIONAL] E2E test user ID (default: Cafe Lucia owner)
E2E_USER_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# CI/CD SECRETS (GitHub Actions)
# ═══════════════════════════════════════════════════════════════════════════════
# These are set as GitHub repository/organization secrets.
# Listed here for documentation completeness — do NOT put real values in .env!

# [CI][SECRET] GitGuardian API key for secret scanning
GITGUARDIAN_API_KEY=

# [CI][SECRET] Load test service token for k6 authenticated endpoints
LOAD_TEST_SERVICE_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# STAGING ENVIRONMENT SPECIFIC VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# These variables are used when deploying to the staging environment.
# Copy the values from your staging Supabase/Redis projects.
#
# IMPORTANT: Add .env.staging to .gitignore to avoid committing secrets!
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Explicitly set staging environment
NODE_ENV=development

# [OPTIONAL][SECRET] Staging Supabase URL (separate from production)
STAGING_SUPABASE_URL=https://your-staging-project.supabase.co

# [OPTIONAL][SECRET] Staging Supabase publishable key
STAGING_SUPABASE_PUBLISHABLE_KEY=your_staging_publishable_key

# [OPTIONAL][SECRET] Staging Supabase service role key
STAGING_SUPABASE_SECRET_KEY=your_staging_service_role_key

# [OPTIONAL][SECRET] Staging application URL
STAGING_APP_URL=https://staging.lole.app

# [OPTIONAL][SECRET] Staging Upstash Redis URL
STAGING_UPSTASH_REDIS_REST_URL=https://your-staging-redis.upstash.io

# [OPTIONAL][SECRET] Staging Upstash Redis token
STAGING_UPSTASH_REDIS_REST_TOKEN=your_staging_redis_token

# [OPTIONAL][SECRET] Staging Sentry DSN
STAGING_SENTRY_DSN=https://your-staging-key@o0.ingest.sentry.io/0

# [OPTIONAL][SECRET] Staging QR HMAC secret (for guest session URLs)
STAGING_QR_HMAC_SECRET=your_staging_hmac_secret

# [OPTIONAL][SECRET] Staging Vercel project ID (separate from production)
VERCEL_PROJECT_ID_STAGING=your_staging_project_id

# [OPTIONAL][PUBLIC] Show staging banner in UI
NEXT_PUBLIC_SHOW_STAGING_BANNER=false
