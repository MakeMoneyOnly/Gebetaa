# ═══════════════════════════════════════════════════════════════════════════════
# GEBETA RESTAURANT OS - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Complete list of all environment variables needed for the platform.
# Copy this file to .env.local and fill in your values.
#
# Legend:
#   [REQUIRED]  - Must be set for the application to work
#   [OPTIONAL]  - Enhances functionality but not required
#   [SECRET]    - Never expose to client-side (server-only)
#   [PUBLIC]    - Safe to expose to client-side (NEXT_PUBLIC_ prefix)
#   [SPRINT]    - Required for specific implementation sprint
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# CORE APPLICATION
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Application URL (used for generating links, webhooks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] Application name (defaults to "Gebeta")
NEXT_PUBLIC_APP_NAME=Gebeta

# [OPTIONAL] Version for health checks and monitoring
NEXT_PUBLIC_VERSION=0.1.0

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE - PRIMARY DATABASE & AUTH
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Modern publishable key (format: sb_publishable_...)
# Used for client-side authentication
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# [REQUIRED][SECRET] Service role key - NEVER expose to client!
# Used for server-side admin operations
SUPABASE_SECRET_KEY=your_service_role_key_here

# [OPTIONAL][SECRET] Database connection string for direct Postgres access
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# [OPTIONAL][SECRET] Supabase access token for CLI/CI operations
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE - CONNECTION POOLING (SUPAVISOR)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Enable connection pooling via Supavisor
# Set to 'true' to use the pooler endpoint
# Pooler URL format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres
NEXT_PUBLIC_SUPABASE_POOLER_ENABLED=false

# [OPTIONAL] Connection pool mode: 'transaction' (default) or 'session'
# - transaction: Connections are borrowed for a single query/transaction
# - session: Connections persist for the full client session
# Use 'session' only if you need PostgreSQL session features (e.g., prepared statements, temporary tables)
SUPABASE_POOL_MODE=transaction

# [OPTIONAL] Pool size: number of connections per pooler instance (default: 10)
# Range: 1-50. For production, start with 10-20 based on expected concurrent users
# Each Vercel function instance gets its own pool
SUPABASE_POOL_SIZE=10

# [OPTIONAL] Maximum number of clients in the pool (default: 20)
SUPABASE_POOL_MAX_CLIENTS=20

# [OPTIONAL] Connection timeout in seconds (default: 30)
# Time to wait for a connection from the pool
SUPABASE_POOL_CONNECTION_TIMEOUT=30

# [OPTIONAL] Idle timeout in seconds (default: 1800 = 30 minutes)
# Time before closing idle connections
SUPABASE_POOL_IDLE_TIMEOUT=1800

# [OPTIONAL][SECRET] Database connection string for Supavisor pooler
# Format: postgresql://postgres:[PASSWORD]@pooler.[PROJECT-REF].supabase.co:6543/postgres
# Only needed if using pooler endpoint directly
SUPABASE_POOLER_URL=postgresql://postgres:password@pooler.your-project.supabase.co:6543/postgres

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED][SECRET] JWT secret for token signing (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# [REQUIRED][SECRET] HMAC secret for QR code signing (min 32 characters)
# Used for guest menu session URLs
HMAC_SECRET=your-super-secret-hmac-key-at-least-32-chars

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENTS - CHAPA (Ethiopian Payment Gateway)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Chapa secret key for payment API
# Get from: https://chapa.co/dashboard
CHAPA_SECRET_KEY=your_chapa_secret_key

# [OPTIONAL][SECRET] Chapa webhook secret for signature verification
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret

# ═══════════════════════════════════════════════════════════════════════════════
# UPSTASH - REDIS CACHE & EVENT BUS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Upstash Redis REST URL
# Used for: menu caching, session storage, rate limiting, event bus (Redis Streams)
# Get from: https://upstash.com/console
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# [OPTIONAL][SECRET] Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# [OPTIONAL] Legacy Redis URL (alternative to Upstash REST API)
REDIS_URL=redis://default:password@redis-host:6379

# ═══════════════════════════════════════════════════════════════════════════════
# UPSTASH QSTASH - JOB QUEUE [SPRINT 1.4]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] QStash token for background job processing
# Used for: payment retries, ERCA submissions, EOD reports, loyalty awards
# Get from: https://upstash.com/console/qstash
QSTASH_TOKEN=your_qstash_token

# [OPTIONAL] Current signing key for QStash webhook verification
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key

# [OPTIONAL] Next signing key for QStash webhook verification
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# ═══════════════════════════════════════════════════════════════════════════════
# POWERSYNC - OFFLINE-FIRST SYNC [SPRINT 4]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] PowerSync instance URL
# Used for: offline-first POS/KDS sync with CRDT conflict resolution
# Get from: https://console.powersync.com/
POWERSYNC_URL=https://your-instance.powersync.co

# [OPTIONAL][SECRET] PowerSync JWT secret for authentication
POWERSYNC_JWT_SECRET=your_powersync_jwt_secret

# ═══════════════════════════════════════════════════════════════════════════════
# APOLLO GRAPHQL - API FEDERATION [SPRINT 6]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Apollo Studio graph ID for schema management
# Get from: https://studio.apollographql.com/
APOLLO_GRAPH_ID=your_graph_id

# [OPTIONAL][SECRET] Apollo Studio API key
APOLLO_KEY=your_apollo_key

# [OPTIONAL][SECRET] Apollo router supergraph schema path
APOLLO_ROUTER_SUPERGRAPH_PATH=./supergraph.graphql

# [OPTIONAL] Enable GraphQL introspection in Apollo Router (disabled by default for security)
# Set to 'true' only in development environments
APOLLO_ROUTER_INTROSPECTION=false

# ═══════════════════════════════════════════════════════════════════════════════
# SENTRY - ERROR MONITORING [SPRINT 1.6]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][PUBLIC] Sentry DSN for client-side error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# [OPTIONAL][SECRET] Sentry auth token for server-side operations
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ═══════════════════════════════════════════════════════════════════════════════
# TELEGRAM - ALERTING [SPRINT 7.6]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Telegram bot token for sending alerts
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# [OPTIONAL] Telegram chat ID for receiving alerts
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_ALERT_CHAT_ID=your_telegram_chat_id

# [OPTIONAL] Telegram chat ID for EOD reports (can be same as ALERT_CHAT_ID)
# Per-restaurant EOD reports will be sent to owner_telegram_id in database
# This is the fallback for system-wide alerts
TELEGRAM_EOD_CHAT_ID=your_telegram_chat_id

# ═══════════════════════════════════════════════════════════════════════════════
# METRICS - API MONITORING DASHBOARDS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] API key for /api/metrics endpoint
# Used for internal service authentication to the metrics API
METRICS_API_KEY=your_metrics_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# AFRICA'S TALKING - SMS NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] SMS provider: 'africas_talking' or 'log' (default: 'log')
SMS_PROVIDER=log

# [OPTIONAL][SECRET] Africa's Talking API key
# Get from: https://account.africastalking.com/
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key

# [OPTIONAL] Africa's Talking username
AFRICAS_TALKING_USERNAME=your_username

# [OPTIONAL] Sender ID (alphanumeric, max 11 chars) for SMS
AFRICAS_TALKING_SENDER_ID=GEBETA

# ═══════════════════════════════════════════════════════════════════════════════
# KDS PRINTER WEBHOOK
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Secret for KDS printer webhook authentication
KDS_PRINTER_WEBHOOK_SECRET=your_printer_webhook_secret

# ═══════════════════════════════════════════════════════════════════════════════
# ERCA - ETHIOPIAN REVENUE COMPLIANCE [SPRINT 8]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] ERCA e-Invoice API URL (production or sandbox)
ERCA_API_URL=https://erca.gov.et/api/invoices

# [OPTIONAL][SECRET] ERCA API key for e-invoicing
ERCA_API_KEY=your_erca_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUDFLARE - CDN, WAF & STORAGE [SPRINT 7]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Cloudflare account ID
# Get from: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# [OPTIONAL][SECRET] Cloudflare API token (for Workers, R2, DNS management)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# [OPTIONAL][SECRET] Cloudflare R2 access key ID (S3-compatible storage)
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key

# [OPTIONAL][SECRET] Cloudflare R2 secret access key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key

# [OPTIONAL] Cloudflare R2 bucket name for receipts, menu images, exports
CLOUDFLARE_R2_BUCKET_NAME=gebeta-storage

# [OPTIONAL] Cloudflare R2 public URL
CLOUDFLARE_R2_PUBLIC_URL=https://storage.gebeta.app

# ═══════════════════════════════════════════════════════════════════════════════
# VERCEL - DEPLOYMENT PLATFORM
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Vercel token for CLI/CI deployments
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token

# [OPTIONAL] Vercel organization ID
VERCEL_ORG_ID=your_org_id

# [OPTIONAL] Vercel project ID
VERCEL_PROJECT_ID=your_project_id

# ═══════════════════════════════════════════════════════════════════════════════
# RAILWAY - APOLLO ROUTER HOSTING [SPRINT 6.8]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Railway token for Apollo Router deployment
# Get from: https://railway.app/account/tokens
RAILWAY_TOKEN=your_railway_token

# [OPTIONAL] Railway service name for Apollo Router
RAILWAY_SERVICE_NAME=apollo-router

# ═══════════════════════════════════════════════════════════════════════════════
# ANALYTICS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][PUBLIC] Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# [OPTIONAL] Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Enable offline mode support
ENABLE_OFFLINE_MODE=true

# [OPTIONAL] Enable AR menu feature
ENABLE_AR_MENU=false

# [OPTIONAL] Enable analytics features
ENABLE_ANALYTICS=true

# [OPTIONAL] Enable rate limiting
RATE_LIMIT_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# PILOT ROLLOUT FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Enable P0 pilot rollout
ENABLE_P0_PILOT_ROLLOUT=false

# [OPTIONAL] Enable P1 pilot rollout
ENABLE_P1_PILOT_ROLLOUT=false

# [OPTIONAL] Enable P2 pilot rollout
ENABLE_P2_PILOT_ROLLOUT=false

# [OPTIONAL] Comma-separated list of pilot restaurant IDs
PILOT_RESTAURANT_IDS=

# [OPTIONAL] Block mutations for pilot restaurants (read-only mode)
PILOT_BLOCK_MUTATIONS=false

# ═══════════════════════════════════════════════════════════════════════════════
# SESSION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Session timeout in minutes (default: 30)
SESSION_TIMEOUT_MINUTES=30

# [OPTIONAL] Session max lifetime in hours (default: 8)
SESSION_MAX_LIFETIME_HOURS=8

# ═══════════════════════════════════════════════════════════════════════════════
# MANAGER APP - EXPO/REACT NATIVE [SPRINT 9]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Expo application ID for manager app
EXPO_APP_ID=your_expo_app_id

# [OPTIONAL][SECRET] Expo access token for EAS Build
EXPO_TOKEN=your_expo_token

# ═══════════════════════════════════════════════════════════════════════════════
# DELIVERY CHANNEL INTEGRATIONS [PHASE 2]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] BEU (delivery partner) API key
BEU_API_KEY=your_beu_api_key

# [OPTIONAL] Deliver Addis API key
DELIVER_ADDIS_API_KEY=your_deliver_addis_api_key

# [OPTIONAL] Zmall API key
ZMALL_API_KEY=your_zmall_api_key

# [OPTIONAL] Esoora API key
ESOORA_API_KEY=your_esoora_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# ADDITIONAL PAYMENT PROVIDERS [PHASE 2]
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] CBE Birr merchant ID
CBE_BIRR_MERCHANT_ID=your_merchant_id

# [OPTIONAL][SECRET] CBE Birr API key
CBE_BIRR_API_KEY=your_cbe_birr_api_key

# [OPTIONAL] Amole (Dashen Bank) merchant ID
AMOLE_MERCHANT_ID=your_amole_merchant_id

# [OPTIONAL][SECRET] Amole API key
AMOLE_API_KEY=your_amole_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# STAGING ENVIRONMENT SPECIFIC VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# These variables are used when deploying to the staging environment.
# Copy the values from your staging Supabase/Redis projects.
#
# IMPORTANT: Add .env.staging to .gitignore to avoid committing secrets!
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL][SECRET] Staging Supabase URL (separate from production)
STAGING_SUPABASE_URL=https://your-staging-project.supabase.co

# [OPTIONAL][SECRET] Staging Supabase publishable key
STAGING_SUPABASE_PUBLISHABLE_KEY=your_staging_publishable_key

# [OPTIONAL][SECRET] Staging Supabase service role key
STAGING_SUPABASE_SECRET_KEY=your_staging_service_role_key

# [OPTIONAL][SECRET] Staging application URL
STAGING_APP_URL=https://staging.gebeta.app

# [OPTIONAL][SECRET] Staging Upstash Redis URL
STAGING_UPSTASH_REDIS_REST_URL=https://your-staging-redis.upstash.io

# [OPTIONAL][SECRET] Staging Upstash Redis token
STAGING_UPSTASH_REDIS_REST_TOKEN=your_staging_redis_token

# [OPTIONAL][SECRET] Staging Sentry DSN
STAGING_SENTRY_DSN=https://your-staging-key@o0.ingest.sentry.io/0

# [OPTIONAL][SECRET] Staging QR HMAC secret (for guest session URLs)
STAGING_QR_HMAC_SECRET=your_staging_hmac_secret

# [OPTIONAL][SECRET] Staging Vercel project ID (separate from production)
VERCEL_PROJECT_ID_STAGING=your_staging_project_id

# ═══════════════════════════════════════════════════════════════════════════════
# E2E TESTING - DEVELOPMENT ONLY
# ═══════════════════════════════════════════════════════════════════════════════
# These variables enable E2E test authentication bypass in non-production environments.
# NEVER enable these in production!

# [OPTIONAL] Enable E2E test mode (only works in non-production)
E2E_TEST_MODE=false

# [OPTIONAL][SECRET] Secret value required for E2E auth bypass
# Must match the value sent in x-e2e-bypass-secret header (NOT x-e2e-bypass-auth)
# Header x-e2e-bypass-auth must be set to '1' to trigger bypass
E2E_BYPASS_SECRET=your_e2e_bypass_secret_here