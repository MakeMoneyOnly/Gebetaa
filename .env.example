# =============================================================================
# GEBETA - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# Required variables are marked with [REQUIRED]
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Gebeta

# =============================================================================
# SUPABASE [REQUIRED]
# =============================================================================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# DATABASE
# =============================================================================
# Direct database connection (for migrations, admin tasks)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT secret for additional signing (optional, Supabase handles auth)
JWT_SECRET=your-jwt-secret-min-32-characters-long

# =============================================================================
# SECURITY
# =============================================================================
# HMAC secret for request signing
HMAC_SECRET=your-hmac-secret-min-32-characters-long

# Session configuration
SESSION_TIMEOUT_MINUTES=30
SESSION_MAX_LIFETIME_HOURS=8

# Rate limiting
RATE_LIMIT_ENABLED=true

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stripe (for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# SendGrid (for emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@gebeta.app

# Sentry (for error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_OFFLINE_MODE=true
ENABLE_AR_MENU=false
ENABLE_ANALYTICS=true
ENABLE_P0_PILOT_ROLLOUT=false
PILOT_RESTAURANT_IDS=
PILOT_BLOCK_MUTATIONS=false

# =============================================================================
# ANALYTICS & MONITORING (Optional)
# =============================================================================
NEXT_PUBLIC_GA_ID=
LOG_LEVEL=info

# =============================================================================
# REDIS (Optional - for production session management)
# =============================================================================
# If not set, in-memory sessions will be used (not recommended for production)
REDIS_URL=redis://localhost:6379

# =============================================================================
# CI/CD (GitHub Actions)
# =============================================================================
# These are set in GitHub repository secrets, not in .env files
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_PROJECT_ID
