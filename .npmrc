# ============================================
# Gebeta Restaurant OS - pnpm Configuration
# Enterprise-Grade Dependency Management
# ============================================

# Dependency hoisting configuration
# Using shamefully-hoist=true for compatibility with existing dependencies
# Consider migrating to hoist=false for stricter security in the future
shamefully-hoist=true

# Enforce strict peer dependencies
# Set to false for compatibility with existing dependencies
strict-peer-dependencies=false

# Block exotic sources for transitive dependencies (git repos, tarballs)
# This prevents supply chain attacks from untrusted sources
block-exotic-subdeps=true

# Minimum release age (24 hours) - prevents installing newly published packages
# This protects against malware that gets detected quickly after publication
minimum-release-age=1440

# Trust policy: prevent downgrades in trust level
# This prevents installing packages with reduced trust evidence
trust-policy=no-downgrade

# Node.js version enforcement
engine-strict=true

# Auto-install peers disabled for security
auto-install-peers=false

# Disable script execution by default (pnpm 10+ security feature)
# Only allow scripts from explicitly trusted packages
# This is the most important security setting - prevents malicious postinstall scripts
# We'll use allowBuilds in package.json pnpm section for trusted packages

# Use frozen lockfile in CI
# This is enforced by CI commands with --frozen-lockfile flag

# Side effects cache for faster installs
side-effects-cache=true

# Shamefully-hoist is false for security (already set above)
# This ensures each package only sees its declared dependencies