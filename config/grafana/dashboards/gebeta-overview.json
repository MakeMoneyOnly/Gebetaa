{
    "annotations": { "list": [] },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "reqps" },
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
            "id": 1,
            "title": "Order Throughput",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(gebeta_orders_created_total[5m])",
                    "legendFormat": "orders/sec",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "percentunit" },
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
            "id": 2,
            "title": "Error Rate",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "sum(rate(gebeta_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(gebeta_http_requests_total[5m]))",
                    "legendFormat": "error rate",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "s" },
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
            "id": 3,
            "title": "Response Times (P50, P95, P99)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "histogram_quantile(0.5, sum(rate(gebeta_http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P50",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(gebeta_http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P95",
                    "refId": "B"
                },
                {
                    "expr": "histogram_quantile(0.99, sum(rate(gebeta_http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P99",
                    "refId": "C"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
            "id": 4,
            "title": "Active Connections",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "gebeta_realtime_connections",
                    "legendFormat": "realtime",
                    "refId": "A"
                },
                {
                    "expr": "gebeta_db_connections_active",
                    "legendFormat": "db_active",
                    "refId": "B"
                },
                {
                    "expr": "gebeta_db_connections_idle",
                    "legendFormat": "db_idle",
                    "refId": "C"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "locale" },
                "overrides": []
            },
            "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
            "id": 5,
            "title": "Sync Queue Size",
            "type": "stat",
            "targets": [
                {
                    "expr": "gebeta_sync_queue_size",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "percentunit" },
                "overrides": []
            },
            "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
            "id": 6,
            "title": "DB Pool Utilization",
            "type": "stat",
            "targets": [
                {
                    "expr": "gebeta_db_connections_active / (gebeta_db_connections_active + gebeta_db_connections_idle)",
                    "refId": "A"
                }
            ]
        }
    ],
