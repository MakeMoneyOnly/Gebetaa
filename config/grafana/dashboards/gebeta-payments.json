            "title": "Payment Success Rate by Provider",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "sum(rate(gebeta_payments_processed_total{status=\"success\"}[5m])) by (provider) / sum(rate(gebeta_payments_processed_total[5m])) by (provider)",
