            "id": 2,
            "title": "Payment Processing Time",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "histogram_quantile(0.5, sum(rate(gebeta_payment_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P50",
