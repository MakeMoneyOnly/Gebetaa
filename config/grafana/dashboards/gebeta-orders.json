            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
            "id": 1,
            "title": "Orders by Status",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "gebeta_orders_created_total",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "ops" },
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
            "id": 2,
            "title": "Order Creation Rate",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(gebeta_orders_created_total[5m])",
                    "legendFormat": "created/sec",
                    "refId": "A"
                },
                {
                    "expr": "rate(gebeta_orders_completed_total[5m])",
                    "legendFormat": "completed/sec",
                    "refId": "B"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": { "unit": "s" },
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
            "id": 3,
            "title": "Average Order Completion Time",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "histogram_quantile(0.5, sum(rate(gebeta_order_completion_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P50",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(gebeta_order_completion_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P95",
                    "refId": "B"
                }
            ]
        },
        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
            "id": 4,
            "title": "Split Order Frequency",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(gebeta_orders_created_total{split=\"true\"}[5m])",
                    "legendFormat": "split orders/sec",
                    "refId": "A"
                }
            ]
        }
